+/* macOS exposes the malloc-zone API in <malloc/malloc.h>, including
+   malloc_zone_pressure_relief(), which asks the allocator to munmap
+   fully-free pages back to the operating system.  Emacs is built with
+   SYSTEM_MALLOC on Darwin, so it cannot itself return freed Lisp
+   memory to the OS; the result is that resident size (RSS) ratchets
+   upward over a long session as freed blocks accumulate in the zone
+   free lists and keep pages resident.  Compacting the zones after GC
+   reclaims those pages, shrinking the footprint and improving cache
+   locality.  See bug#... (macOS memory growth).  */
+#ifdef HAVE_MALLOC_MALLOC_H
+# include <malloc/malloc.h>
+#endif
+
 #include <errno.h>
 #include <stdint.h>
 #include <stdlib.h>
@@ -5798,6 +5811,108 @@
   return Qnil;
 }
 
+/* Malloc-zone compaction (memory pressure relief).
+
+   On platforms that provide malloc_zone_pressure_relief() (macOS),
+   ask the system allocator to release fully-free pages back to the
+   operating system.  Emacs uses the system allocator (SYSTEM_MALLOC)
+   on Darwin, so freed Lisp objects merely land on the zone's free
+   lists and keep their pages resident; over a long session this
+   ratchets resident size (RSS) upward and degrades cache locality.
+
+   GOAL of 0 means "release as much as possible".  A non-zero GOAL
+   asks the allocator to target that many bytes.  Returns the number
+   of bytes actually released (best-effort; the allocator may release
+   more or less).
+
+   Passing a NULL zone iterates over every registered zone, which is
+   what we want.  This is the documented public API (available since
+   macOS 10.7) and avoids the task-port and zone-enumeration pitfalls
+   of a hand-rolled loop over malloc_get_all_zones().
+
+   This is not a moving/compacting collector: it cannot relocate live
+   objects, so it does not cure internal fragmentation (a page kept
+   resident by a single live object).  It only reclaims pages that are
+   entirely free.  It is therefore most effective right after a GC,
+   which is where garbage_collect() calls it.  */
+
+#ifdef HAVE_MALLOC_MALLOC_H
+static size_t
+malloc_zone_compact (void)
+{
+  /* malloc_zone_pressure_relief (NULL, 0) examines every zone and
+     makes its best effort to munmap free pages (0 = maximal).  */
+  return malloc_zone_pressure_relief (NULL, 0);
+}
+#endif
+
+/* Statistics accumulated across the session.  These are kept as
+   file-static counters rather than DEFVAR_INT globals to avoid
+   churning the auto-generated globals.h table.  */
+#ifdef HAVE_MALLOC_MALLOC_H
+static uintmax_t memory_compacts_done;
+static uintmax_t memory_compact_bytes_returned;
+#endif
+
+/* Minimum number of bytes that must have been freed by a GC before we
+   consider compacting the malloc zones afterwards.  Compaction walks
+   the whole arena, so doing it on every GC (especially in a -O0 build
+   that GCs often) adds avoidable latency.  We only run it when a GC
+   freed a worthwhile amount, i.e. when there is likely to be
+   returnable memory.  */
+#define MEMORY_COMPACT_FREED_THRESHOLD (4 * 1024 * 1024)
+
+/* Safety net: even if individual GCs free little, flush fragmentation
+   at least this often so gradual leakage does not accumulate
+   unchecked between large collections.  */
+#define MEMORY_COMPACT_EVERY_N_GCS 64
+
+/* Avoid running compaction more often than this, to prevent
+   pathological churn on allocation-heavy workloads where many small
+   GCs each cross the freed threshold.  */
+#define MEMORY_COMPACT_MIN_INTERVAL_SECS 3
+
+/* Decide whether to run malloc-zone compaction after a GC that freed
+   FREED_BYTES of live data, and if so run it.  Called at the very end
+   of garbage_collect(), after all sweeping and before post-gc-hook,
+   so the allocator free lists are as empty as they will get.  */
+
+#ifdef HAVE_MALLOC_MALLOC_H
+static void
+maybe_compact_memory_after_gc (byte_ct freed_bytes)
+{
+  /* GCs are not reentrant and input is blocked for most of GC, so the
+     file-static state below does not need a lock.  */
+  static uintmax_t gc_counter;
+  static struct timespec last_compact;
+  static bool last_compact_set;
+
+  bool crossed_threshold = ((byte_ct) MEMORY_COMPACT_FREED_THRESHOLD
+			    <= freed_bytes);
+  bool periodic = (++gc_counter >= MEMORY_COMPACT_EVERY_N_GCS);
+  if (!crossed_threshold && !periodic)
+    return;
+
+  struct timespec now = current_timespec ();
+  if (last_compact_set)
+    {
+      struct timespec elapsed = timespec_sub (now, last_compact);
+      if (timespectod (elapsed) < MEMORY_COMPACT_MIN_INTERVAL_SECS)
+	return;
+    }
+
+  /* 0 = release as much as possible.  */
+  size_t released = malloc_zone_compact ();
+  memory_compacts_done++;
+  memory_compact_bytes_returned += released;
+  last_compact = now;
+  last_compact_set = true;
+
+  /* Help the profiler/allocator notice the change in footprint.  */
+  MALLOC_PROBE (released);
+}
+#endif	/* HAVE_MALLOC_MALLOC_H */
+
 /* It may be time to collect garbage.  Recalculate consing_until_gc,
    since it might depend on current usage, and do the garbage
    collection if the recalculation says so.  */
@@ -6012,13 +6127,23 @@
   gcs_done++;
 
   /* Collect profiling data.  */
+  byte_ct freed_bytes = 0;
   if (tot_before != (byte_ct) -1)
     {
       byte_ct tot_after = total_bytes_of_live_objects ();
       if (tot_after < tot_before)
-	malloc_probe (min (tot_before - tot_after, SIZE_MAX));
+	{
+	  freed_bytes = tot_before - tot_after;
+	  malloc_probe (min (freed_bytes, SIZE_MAX));
+	}
     }
 
+  /* Return fully-free malloc pages to the OS (macOS).  Gated so we
+     don't pay the arena walk on every GC; see maybe_compact_memory_after_gc.  */
+#ifdef HAVE_MALLOC_MALLOC_H
+  maybe_compact_memory_after_gc (freed_bytes);
+#endif
+
   if (!NILP (Vpost_gc_hook))
     {
       specpdl_ref gc_count = inhibit_garbage_collection ();
diff --git a/src/nsterm.m b/src/nsterm.m
index a7f3fc292c..4490dadd37 100644
--- a/src/nsterm.m
+++ b/src/nsterm.m
@@ -151,6 +151,68 @@
 
 /* ==========================================================================
 
+   NSColor cache.
+
+   ========================================================================== */
+/* Cache of NSColor objects keyed by their packed 32-bit pixel value.
+
+   Emacs derives NSColor objects from raw face pixels on every glyph run
+   (see the many callers of +colorWithUnsignedLong: below, in nsfont_draw
+   and ns_draw_glyph_string).  Each call allocates and autoreleases a new
+   NSColor and performs colorspace conversion, which is pure overhead
+   given that faces use a small, bounded set of colors.  This direct-
+   mapped cache returns the same NSColor for a given pixel across the
+   whole process, eliminating the per-glyph allocation and conversion.
+
+   Drawing always happens on the main thread, so no locking is needed.
+   The cache never evicts an entry once claimed, so a pointer handed back
+   to a caller stays valid for the process lifetime; a hash collision on
+   a given slot simply misses the cache for that key (rare for the
+   handful of colors in use).  */
+
+#define NS_COLOR_CACHE_SIZE 32768
+
+static NSColor *ns_color_cache[NS_COLOR_CACHE_SIZE];
+static unsigned long ns_color_cache_keys[NS_COLOR_CACHE_SIZE];
+
+static NSUInteger
+ns_color_cache_index (unsigned long key)
+{
+  /* Fibonacci hashing spreads packed ARGB keys uniformly.
+     Used so that low bits don't dominate the cache.  */
+  return (NSUInteger) ((key * 11400714819323198485ULL)
+		       & (NS_COLOR_CACHE_SIZE - 1));
+}
+
+static NSColor *
+ns_color_cache_lookup (unsigned long key)
+{
+  NSUInteger i = ns_color_cache_index (key);
+  if (ns_color_cache[i] != nil && ns_color_cache_keys[i] == key)
+    return ns_color_cache[i];
+  return nil;
+}
+
+/* Store COL under KEY, retaining it for the cache lifetime when the
+   slot is free.  Returns the object the caller should use: the cached
+   object when stored, or the freshly-created (autoreleased) COL when the
+   slot was already occupied by a colliding key.  */
+static NSColor *
+ns_color_cache_store (unsigned long key, NSColor *col)
+{
+  NSUInteger i = ns_color_cache_index (key);
+  if (ns_color_cache[i] == nil)
+    {
+      ns_color_cache[i] = [col retain];
+      ns_color_cache_keys[i] = key;
+      return ns_color_cache[i];
+    }
+  return col;
+}
+
+
+/* ==========================================================================
+
    NSColor, EmacsColor category.
 
    ========================================================================== */
@@ -184,12 +246,17 @@
 
 + (NSColor *)colorWithUnsignedLong:(unsigned long)c
 {
+  NSColor *cached = ns_color_cache_lookup (c);
+  if (cached != nil)
+    return cached;
+
   EmacsCGFloat a = (double)((c >> 24) & 0xff) / 255.0;
   EmacsCGFloat r = (double)((c >> 16) & 0xff) / 255.0;
   EmacsCGFloat g = (double)((c >> 8) & 0xff) / 255.0;
   EmacsCGFloat b = (double)(c & 0xff) / 255.0;
 
-  return [NSColor colorForEmacsRed:r green:g blue:b alpha:a];
+  NSColor *col = [NSColor colorForEmacsRed:r green:g blue:b alpha:a];
+  return ns_color_cache_store (c, col);
 }
 
 - (unsigned long)unsignedLong
