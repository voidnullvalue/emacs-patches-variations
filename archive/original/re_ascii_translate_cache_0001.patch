 		  {
@@ -4563,7 +4579,7 @@
 
 		if (! CHAR_BYTE8_P (c1))
 		  {
-		    c1 = TRANSLATE (c1);
+		    c1 = TRANSLATE_TRU (c1);
 		    c1 = RE_CHAR_TO_UNIBYTE (c1);
 		    if (c1 >= 0)
 		      {
@@ -5348,6 +5364,24 @@
 		       whitespace_regexp,
 		       bufp);
 
+  /* Populate the flat ASCII translate cache so the hot match/scan
+     loops can avoid the expensive char-table walk for single-byte
+     characters.  Multibyte characters (code > 255) always take the
+     slow path through char_table_translate, so this changes nothing
+     for non-ASCII text.  */
+  if (!ret && !NILP (bufp->translate))
+    {
+      for (int i = 0; i < 256; i++)
+	{
+	  int ch = char_table_translate (bufp->translate, i);
+	  int byte = CHAR_TO_BYTE_SAFE (ch);
+	  bufp->trt_ascii[i] = (byte >= 0 ? byte : i);
+	}
+      bufp->trt_ascii_valid = true;
+    }
+  else
+    bufp->trt_ascii_valid = false;
+
   if (!ret)
     return NULL;
   return re_error_msgid[ret];
