   Lisp_Object translate;
 
+        /* Flat lookup table caching the ASCII (0-255) portion of the
+           translate table above, so that the hot match/scan loops can
+           avoid the expensive char-table walk for the overwhelmingly
+           common case of single-byte characters.  Valid only when
+           trt_ascii_valid is true; entries for codes >= 128 that have
+           no translation are stored as their own value (identity).
+           Multibyte characters (code > 255) always take the slow path
+           through char_table_translate.  */
+  unsigned char trt_ascii[256];
+
+        /* True iff trt_ascii has been populated from translate.  */
+  bool_bf trt_ascii_valid : 1;
+
 	/* Number of subexpressions found by the compiler.  */
   ptrdiff_t re_nsub;
 
