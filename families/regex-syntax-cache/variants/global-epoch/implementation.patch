 /* Explicit syntax lookup using the buffer-local table.  */
 #define BUFFER_SYNTAX(c) syntax_property (c, 0)

+/* Global ASCII syntax cache with epoch-counter invalidation.
+
+   Instead of storing a per-pattern syntax_ascii array in re_pattern_buffer,
+   maintain a single global cache.  The cache is keyed by the identity of the
+   current syntax table (as a Lisp_Object integer) and is invalidated when a
+   global epoch counter is bumped.
+
+   The epoch is bumped from outside (see search.c, syntax.c) whenever the
+   buffer's syntax table changes.  Patterns compiled against the old syntax
+   table automatically see a cache miss and fall back to syntax_property.
+
+   Benefits over baseline:
+   - O(1) memory regardless of how many patterns are compiled.
+   - Single invalidation point: bump the epoch in syntax_change_hook.
+
+   Costs:
+   - Epoch comparison adds one load + compare per SYNTAX_TRU call.
+   - Global state limits future thread safety.
+   - Only one syntax table's cache is live at a time; buffer-switching
+     causes a cache rebuild.  */
+
+#define GLOBAL_SYNTAX_CACHE_EPOCH_INVALID 0
+
+static unsigned char global_syntax_ascii[128];
+static uintmax_t     global_syntax_epoch;      /* current valid epoch */
+static uintmax_t     global_syntax_epoch_built; /* epoch when cache was filled */
+
+/* Epoch counter incremented by syntax table mutation paths.  */
+uintmax_t emacs_syntax_table_epoch;  /* defined here, declared in syntax.h */
+
+#define SYNTAX_TRU(c)							\
+  (((unsigned)(c) < 128					\
+    && global_syntax_epoch_built == emacs_syntax_table_epoch	\
+    && emacs_syntax_table_epoch != GLOBAL_SYNTAX_CACHE_EPOCH_INVALID) \
+   ? (enum syntaxcode) global_syntax_ascii[(unsigned char)(c)]	\
+   : SYNTAX (c))
+
 #define RE_MULTIBYTE_P(bufp) ((bufp)->multibyte)
 #define RE_TARGET_MULTIBYTE_P(bufp) ((bufp)->target_multibyte)
 #define RE_STRING_CHAR(p, multibyte) \
@@ -4983,12 +5016,12 @@
 		UPDATE_SYNTAX_TABLE (charpos);
