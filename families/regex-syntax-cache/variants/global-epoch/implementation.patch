 	      /* Case 2: S2 is neither Sword nor Ssymbol. */
 	      if (s2 != Sword && s2 != Ssymbol)
@@ -5121,7 +5154,7 @@
 		  GET_CHAR_BEFORE_2 (c1, d, string1, end1, string2, end2);
