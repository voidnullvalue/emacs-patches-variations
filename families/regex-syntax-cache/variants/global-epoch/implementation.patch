+  /* Populate the global ASCII syntax cache if the epoch has advanced.
+     This replaces the per-pattern syntax_ascii array used in the baseline.
+     The check here rebuilds the global cache when it is stale; SYNTAX_TRU
+     then reads it without per-call epoch comparison inside the pattern struct.  */
+  if (!ret && bufp->used_syntax && !parse_sexp_lookup_properties
+      && emacs_syntax_table_epoch != GLOBAL_SYNTAX_CACHE_EPOCH_INVALID
+      && global_syntax_epoch_built != emacs_syntax_table_epoch)
+    {
+      for (int i = 0; i < 128; i++)
+        global_syntax_ascii[i] = syntax_property (i, 0);
+      global_syntax_epoch_built = emacs_syntax_table_epoch;
+    }
