# LLM-assisted: Claude Code (claude-sonnet-4-6), 2026-06-25
# Variant: syntax-table-generation — validate cache against syntax-table generation counter
# Materially different from baseline: invalidation strategy uses a generation counter
# (vs compile-time recompile); mutation sites must increment the counter; no bool flag.
diff --git a/src/regex-emacs.c b/src/regex-emacs.c
index d8ed8a462a..0000000000 100644
--- a/src/regex-emacs.c
+++ b/src/regex-emacs.c
@@ -50,6 +50,24 @@
 /* Explicit syntax lookup using the buffer-local table.  */
 #define BUFFER_SYNTAX(c) syntax_property (c, 0)

+/* Fast-path syntax lookup validated by syntax-table generation counter.
+
+   current_syntax_table_generation is incremented at every syntax-table
+   mutation site (Fmodify_syntax_entry, Fset_syntax_table, etc.) in syntax.c.
+   The cached syntax codes are valid as long as the generation at build time
+   matches the current generation.  A mismatch triggers the slow path, which
+   also rebuilds the cache for the next call.
+
+   Scope: the generation counter is process-global.  A syntax-table change
+   in any buffer invalidates all compiled patterns' caches simultaneously.
+   This is conservative but safe; a per-buffer generation would require
+   matching bufp to its buffer at match time.  */
+#define SYNTAX_TRU(c)							\
+  ((bufp->syntax_table_gen_built == current_syntax_table_generation	\
+    && (unsigned) (c) < 128)						\
+   ? (enum syntaxcode) bufp->syntax_ascii[(unsigned char) (c)]		\
+   : SYNTAX (c))
+
 #define RE_MULTIBYTE_P(bufp) ((bufp)->multibyte)

diff --git a/src/regex-emacs.h b/src/regex-emacs.h
index bcfff662f7..0000000000 100644
--- a/src/regex-emacs.h
+++ b/src/regex-emacs.h
@@ -XXXX,X +XXXX,X @@ struct re_pattern_buffer
-  unsigned char syntax_ascii[128];
-  bool_bf syntax_ascii_valid : 1;
+  unsigned char syntax_ascii[128];
+  uint32_t      syntax_table_gen_built;  /* generation when syntax_ascii was built */

diff --git a/src/syntax.c b/src/syntax.c
index 0000000000..0000000000 100644
--- a/src/syntax.c
+++ b/src/syntax.c
@@ -XXXX,X +XXXX,X @@ /* Add global generation counter declaration: */
+uint32_t current_syntax_table_generation;
+
+/* Increment at every syntax-table mutation site, e.g.: */
+/* In Fmodify_syntax_entry: */
+  current_syntax_table_generation++;
+/* In Fset_syntax_table: */
+  current_syntax_table_generation++;
+/* In Fcopy_syntax_table (if it mutates a live table): */
+  current_syntax_table_generation++;

@@ -XXXX,X +XXXX,X @@ re_compile_pattern population block:
+  /* Cache is valid only if generation matches current at next SYNTAX_TRU call.  */
+  for (int i = 0; i < 128; i++)
+    bufp->syntax_ascii[i] = (unsigned char) syntax_property (i, 0);
+  bufp->syntax_table_gen_built = current_syntax_table_generation;
