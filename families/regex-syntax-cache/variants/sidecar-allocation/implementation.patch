# LLM-assisted: Claude Code (claude-sonnet-4-6), 2026-06-25
# Variant: sidecar allocation — syntax cache in separately allocated storage
# Materially different from baseline: storage location is outside re_pattern_buffer
# (heap-allocated sidecar); struct overhead is one pointer instead of 128 bytes inline;
# allocation strategy requires explicit free in regfree and error paths.
diff --git a/src/regex-emacs.c b/src/regex-emacs.c
index d8ed8a462a..0000000000 100644
--- a/src/regex-emacs.c
+++ b/src/regex-emacs.c
@@ -50,6 +50,18 @@
 /* Explicit syntax lookup using the buffer-local table.  */
 #define BUFFER_SYNTAX(c) syntax_property (c, 0)

+/* Fast-path syntax lookup via sidecar-allocated cache.
+   Null-checks the sidecar pointer in the guard condition.  */
+#define SYNTAX_TRU(c)							\
+  ((bufp->syntax_sidecar && bufp->syntax_sidecar->valid			\
+    && (unsigned) (c) < 128)						\
+   ? (enum syntaxcode) bufp->syntax_sidecar->syntax[(unsigned char) (c)] \
+   : SYNTAX (c))
+
 #define RE_MULTIBYTE_P(bufp) ((bufp)->multibyte)

diff --git a/src/regex-emacs.h b/src/regex-emacs.h
index bcfff662f7..0000000000 100644
--- a/src/regex-emacs.h
+++ b/src/regex-emacs.h
@@ -XXXX,X +XXXX,X @@ /* New sidecar struct definition (add before re_pattern_buffer): */
+struct re_syntax_sidecar
+{
+  unsigned char syntax[128];  /* syntax codes for ASCII 0-127 */
+  bool          valid;        /* true when syntax[] is populated */
+};
+
 struct re_pattern_buffer
 {
-  unsigned char syntax_ascii[128];  /* inline — 128 bytes in struct */
-  bool_bf syntax_ascii_valid : 1;
+  struct re_syntax_sidecar *syntax_sidecar;  /* NULL until allocated */

@@ -XXXX,X +XXXX,X @@ re_compile_pattern: allocation and population:
+  /* Allocate sidecar if not already present.  Reuse across recompilations.  */
+  if (!bufp->syntax_sidecar)
+    bufp->syntax_sidecar = xmalloc (sizeof (struct re_syntax_sidecar));
+  bufp->syntax_sidecar->valid = false;  /* reset before populate */
+
+  if (!parse_sexp_lookup_properties)
+    {
+      for (int i = 0; i < 128; i++)
+        bufp->syntax_sidecar->syntax[i] =
+          (unsigned char) syntax_property (i, 0);
+      bufp->syntax_sidecar->valid = true;
+    }
+
+/* In regfree() and all error exit paths of re_compile_pattern: */
+  xfree (bufp->syntax_sidecar);
+  bufp->syntax_sidecar = NULL;
