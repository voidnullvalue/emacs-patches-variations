# LLM-assisted: Claude Code (claude-sonnet-4-6), 2026-06-25
# Variant: 256-entry syntax cache covering byte codes 0-255
# Materially different from baseline: cache size extended from 128 to 256 entries;
# coverage extended from ASCII (0-127) to full byte range (0-255);
# macro threshold changed from (unsigned)(c) < 128 to < 256.
diff --git a/src/regex-emacs.c b/src/regex-emacs.c
index d8ed8a462a..0000000000 100644
--- a/src/regex-emacs.c
+++ b/src/regex-emacs.c
@@ -50,6 +50,20 @@
 /* Explicit syntax lookup using the buffer-local table.  */
 #define BUFFER_SYNTAX(c) syntax_property (c, 0)

+/* Fast-path syntax lookup for byte codes 0-255.
+   Extends the baseline's 128-entry cache to the full byte range.
+
+   For unibyte buffers, byte codes 128-255 represent raw octets whose
+   syntax is determined by the unibyte syntax table.  Caching them avoids
+   a syntax_property call on every word-boundary opcode evaluation.
+
+   For multibyte buffers, byte codes 128-255 are rarely encountered as
+   standalone values in word-boundary comparisons (they appear as leading
+   bytes of multibyte sequences); the fast path fires only when the value
+   is truly < 256 as an unsigned int, which is always true for unsigned char.
+   Callers that pass char values should cast to unsigned char before this macro.  */
+#define SYNTAX_TRU(c)							\
+  ((bufp->syntax_ascii_valid && (unsigned) (c) < 256)			\
+   ? (enum syntaxcode) bufp->syntax_ascii[(unsigned char) (c)]		\
+   : SYNTAX (c))
+
 #define RE_MULTIBYTE_P(bufp) ((bufp)->multibyte)

diff --git a/src/regex-emacs.h b/src/regex-emacs.h
index bcfff662f7..0000000000 100644
--- a/src/regex-emacs.h
+++ b/src/regex-emacs.h
@@ -XXXX,X +XXXX,X @@ struct re_pattern_buffer
-  unsigned char syntax_ascii[128];   /* ASCII syntax codes (0-127) */
+  unsigned char syntax_ascii[256];   /* syntax codes for byte codes 0-255 */
   bool_bf syntax_ascii_valid : 1;

@@ -XXXX,X +XXXX,X @@ re_compile_pattern population block:
-  for (int i = 0; i < 128; i++)
+  for (int i = 0; i < 256; i++)
     bufp->syntax_ascii[i] = (unsigned char) syntax_property (i, 0);
   bufp->syntax_ascii_valid = true;
