+  /* Populate the flat ASCII syntax cache so the hot match opcodes
+     (wordbeg, wordend, wordbound, etc.) can avoid the expensive
+     char-table walk for single-byte characters.  This is only safe
+     when syntax properties are not in use, because otherwise the
+     syntax code of a character can vary by position via the
+     syntax-table text property.  Multibyte characters (code > 127)
+     always take the slow path regardless.  */
+  if (!ret && bufp->used_syntax && !parse_sexp_lookup_properties)
+    {
+      for (int i = 0; i < 128; i++)
+	bufp->syntax_ascii[i] = syntax_property (i, 0);
+      bufp->syntax_ascii_valid = true;
+    }
+  else
+    bufp->syntax_ascii_valid = false;
+
