+  /* Populate both caches and stamp the generation.  Both caches are always
+     built together: if either table is absent the whole cache is skipped.  */
+  bool have_translate = !ret && !NILP (bufp->translate);
+  bool have_syntax   = !ret && bufp->used_syntax && !parse_sexp_lookup_properties;
+
+  if (have_translate && have_syntax)
+    {
+      for (int i = 0; i < 256; i++)
+	{
+	  int ch = char_table_translate (bufp->translate, i);
+	  int byte = CHAR_TO_BYTE_SAFE (ch);
+	  bufp->trt_ascii[i] = (byte >= 0 ? byte : i);
+	}
+      for (int i = 0; i < 128; i++)
+	bufp->syntax_ascii[i] = syntax_property (i, 0);
+      bufp->cache_gen = re_global_cache_gen;
+    }
+  else if (have_translate)
+    {
+      for (int i = 0; i < 256; i++)
+	{
+	  int ch = char_table_translate (bufp->translate, i);
+	  int byte = CHAR_TO_BYTE_SAFE (ch);
+	  bufp->trt_ascii[i] = (byte >= 0 ? byte : i);
+	}
+      bufp->cache_gen = re_global_cache_gen;
+      /* syntax_ascii is NOT populated; SYNTAX_TRU will see cache_gen match
+         but syntax_ascii_ready guards it — see DESIGN.md for the separate
+         per-cache ready flags alongside the unified generation.  */
+    }
+  else
+    bufp->cache_gen = 0;   /* 0 = invalid, forces slow path */
+
   if (!ret)
     return NULL;
   return re_error_msgid[ret];
