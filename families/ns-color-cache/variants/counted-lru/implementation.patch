 /* ==========================================================================

+   NSColor cache — CLOCK-approximation LRU variant.
+
+   ========================================================================== */
+/* 64-slot cache with CLOCK-hand eviction for NSColor objects.
+
+   The CLOCK algorithm approximates LRU using a single reference bit per slot
+   and a rotating "clock hand".  On insertion, the hand advances past slots
+   whose reference bit is set (clearing the bit as it goes) until it finds a
+   slot whose reference bit is clear, then evicts that slot.  On a cache hit,
+   the reference bit is set.
+
+   This gives LRU-like behavior with O(1) worst-case eviction cost per
+   insertion (one pass of the clock hand, bounded by table size).
+
+   Rationale for 64 slots: typical Emacs sessions use 20-50 distinct colors.
+   A 64-slot table provides sufficient capacity with negligible memory overhead
+   (< 2 KB including keys, pointers, and reference bits).  If sessions
+   regularly exceed 64 active colors, increase NS_COLOR_LRU_SIZE.  */
+
+#define NS_COLOR_LRU_SIZE 64
+
+typedef struct {
+  NSColor      *color;
+  unsigned long key;
+  bool          ref;   /* reference bit for CLOCK eviction */
+  bool          occupied;
+} NsColorLRUEntry;
+
+static NsColorLRUEntry ns_lru_table[NS_COLOR_LRU_SIZE];
+static int             ns_lru_hand;   /* clock hand (0..NS_COLOR_LRU_SIZE-1) */
+static int             ns_lru_count;  /* number of occupied slots */
+
+static NSColor *
+ns_lru_lookup (unsigned long key)
+{
+  for (int i = 0; i < NS_COLOR_LRU_SIZE; i++)
+    {
+      if (ns_lru_table[i].occupied && ns_lru_table[i].key == key)
+        {
+          ns_lru_table[i].ref = true;
+          return ns_lru_table[i].color;
+        }
+    }
+  return nil;
+}
+
+static int
+ns_lru_evict_slot (void)
+{
+  /* If table not full, find first unoccupied slot.  */
+  if (ns_lru_count < NS_COLOR_LRU_SIZE)
+    {
+      for (int i = 0; i < NS_COLOR_LRU_SIZE; i++)
+        if (!ns_lru_table[i].occupied)
+          {
+            ns_lru_count++;
+            return i;
+          }
+    }
+
+  /* CLOCK: advance hand, clear ref bits, stop on unref'd slot.  */
+  for (;;)
+    {
+      if (!ns_lru_table[ns_lru_hand].ref)
+        {
+          int slot = ns_lru_hand;
+          ns_lru_hand = (ns_lru_hand + 1) % NS_COLOR_LRU_SIZE;
+          return slot;
+        }
+      ns_lru_table[ns_lru_hand].ref = false;
+      ns_lru_hand = (ns_lru_hand + 1) % NS_COLOR_LRU_SIZE;
+    }
+}
+
+static NSColor *
+ns_lru_insert (unsigned long key, NSColor *col)
+{
+  int slot = ns_lru_evict_slot ();
+
+  if (ns_lru_table[slot].occupied)
+    {
+      [ns_lru_table[slot].color release];
+    }
+
+  ns_lru_table[slot].color    = [col retain];
+  ns_lru_table[slot].key      = key;
+  ns_lru_table[slot].ref      = true;
+  ns_lru_table[slot].occupied = true;
+  return ns_lru_table[slot].color;
+}
+
+
+/* ==========================================================================
+
    NSColor, EmacsColor category.

    ========================================================================== */
@@ -184,12 +288,17 @@

 + (NSColor *)colorWithUnsignedLong:(unsigned long)c
 {
+  NSColor *cached = ns_lru_lookup (c);
+  if (cached != nil)
+    return cached;
+
   EmacsCGFloat a = (double)((c >> 24) & 0xff) / 255.0;
   EmacsCGFloat r = (double)((c >> 16) & 0xff) / 255.0;
   EmacsCGFloat g = (double)((c >> 8) & 0xff) / 255.0;
   EmacsCGFloat b = (double)(c & 0xff) / 255.0;

-  return [NSColor colorForEmacsRed:r green:g blue:b alpha:a];
+  NSColor *col = [NSColor colorForEmacsRed:r green:g blue:b alpha:a];
+  return ns_lru_insert (c, col);
 }

