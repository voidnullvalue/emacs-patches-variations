# LLM-assisted: Claude Code (claude-sonnet-4-6), 2026-06-25
# Variant: idle-triggered — set pending flag during GC, execute during Emacs idle
# Materially different from baseline: no allocator arena walk inside GC critical path;
# trigger policy is deferred; integration point is idle loop (keyboard.c), not GC exit.
diff --git a/src/alloc.c b/src/alloc.c
index 5fc166dbc2..0000000000 100644
--- a/src/alloc.c
+++ b/src/alloc.c
@@ -23,6 +23,10 @@
 # include <malloc.h>
 #endif

+#ifdef HAVE_MALLOC_MALLOC_H
+# include <malloc/malloc.h>
+#endif
+
 #include <errno.h>
 #include <stdint.h>
 #include <stdlib.h>
@@ -5798,6 +5802,80 @@
   return Qnil;
 }

+/* Idle-triggered malloc-zone pressure relief.
+
+   Architecture: the GC completion path sets a lightweight flag to indicate
+   that pressure relief would be useful.  The actual arena walk is deferred
+   to the Emacs idle processing path (called from keyboard.c when there is
+   no pending input), so GC latency is not affected.
+
+   Pending state: a single bool flag is sufficient because:
+   - GC is not reentrant; the flag cannot be set while being read.
+   - The idle path clears the flag before calling malloc_zone_pressure_relief,
+     so a new GC during the walk can re-set it.
+   - Multiple GCs between idle executions do not create duplicate work:
+     the flag is already set after the first GC, so subsequent GCs skip
+     the set operation.
+
+   Shutdown: pending relief is abandoned if Emacs exits before going idle.
+   This is acceptable: the OS reclaims the process's memory on exit.
+
+   Reentrancy: garbage_collect() is not called from the idle path in normal
+   operation.  Even if it were, the flag check at the top of
+   execute_pending_pressure_relief prevents double-execution.  */
+
+#ifdef HAVE_MALLOC_MALLOC_H
+
+#define IDLE_PRESSURE_FREED_THRESHOLD (4 * 1024 * 1024)
+
+/* Set to true by GC completion when freed_bytes crosses threshold.
+   Cleared by execute_pending_pressure_relief before the arena walk.  */
+static bool pressure_relief_pending;
+
+/* Statistics.  */
+static uintmax_t idle_pressure_executions;
+static uintmax_t idle_pressure_bytes_returned;
+
+/* Called from garbage_collect() — sets pending flag, does not walk arena.  */
+void
+maybe_schedule_idle_pressure_relief (byte_ct freed_bytes)
+{
+  if (pressure_relief_pending)
+    return;   /* already scheduled; don't accumulate duplicates */
+  if (freed_bytes >= (byte_ct) IDLE_PRESSURE_FREED_THRESHOLD)
+    pressure_relief_pending = true;
+}
+
+/* Called from the Emacs idle path in keyboard.c.
+   Returns true if relief was executed.  */
+bool
+execute_pending_pressure_relief (void)
+{
+  if (!pressure_relief_pending)
+    return false;
+  pressure_relief_pending = false;   /* clear before walk (re-entrant-safe) */
+  size_t released = malloc_zone_pressure_relief (NULL, 0);
+  idle_pressure_executions++;
+  idle_pressure_bytes_returned += released;
+  return true;
+}
+
+#else /* !HAVE_MALLOC_MALLOC_H */
+
+void
+maybe_schedule_idle_pressure_relief (byte_ct freed_bytes)
+{
+  (void) freed_bytes;
+}
+
+bool
+execute_pending_pressure_relief (void)
+{
+  return false;
+}
+
+#endif /* HAVE_MALLOC_MALLOC_H */
+
 /* It may be time to collect garbage.  */
@@ -6012,8 +6092,13 @@
   gcs_done++;

   /* Collect profiling data.  */
+  byte_ct freed_bytes = 0;
   if (tot_before != (byte_ct) -1)
     {
       byte_ct tot_after = total_bytes_of_live_objects ();
       if (tot_after < tot_before)
-	malloc_probe (min (tot_before - tot_after, SIZE_MAX));
+	{
+	  freed_bytes = tot_before - tot_after;
+	  malloc_probe (min (freed_bytes, SIZE_MAX));
+	}
     }
+  maybe_schedule_idle_pressure_relief (freed_bytes);

