# Variant: background GCD dispatch of malloc_zone_pressure_relief
# Materially different from baseline: timing model (async via libdispatch vs
# synchronous), GC pause impact (zero vs small pause), thread model (background
# thread vs main thread), synchronization (atomic flag vs none).
diff --git a/src/alloc.c b/src/alloc.c
