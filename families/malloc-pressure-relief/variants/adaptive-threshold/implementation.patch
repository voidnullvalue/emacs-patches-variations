+/* Adaptive malloc-zone compaction.  */
+
+#ifdef HAVE_MALLOC_MALLOC_H
+
+/* EMA smoothing factor: new_ema = alpha * sample + (1-alpha) * old_ema.
+   A value of 0.25 gives ~75% weight to recent history.  */
+#define ADAPTIVE_EMA_ALPHA_NUM 1
+#define ADAPTIVE_EMA_ALPHA_DEN 4

+/* Initial threshold: 4 MB, same as baseline.  Updated after first compaction.  */
+#define ADAPTIVE_THRESHOLD_INITIAL (4ULL * 1024 * 1024)

+/* Minimum and maximum threshold values, as multiples of the EMA.
+   Threshold is clamped to [EMA * 0.5, EMA * 4.0] to prevent
+   oscillation and runaway adaptation.  */
+#define ADAPTIVE_THRESH_MIN_SCALE_NUM 1
+#define ADAPTIVE_THRESH_MIN_SCALE_DEN 2
+#define ADAPTIVE_THRESH_MAX_SCALE_NUM 4
+#define ADAPTIVE_THRESH_MAX_SCALE_DEN 1

+/* Minimum wall-clock seconds between compactions (same as baseline).  */
+#define ADAPTIVE_MIN_INTERVAL_SECS 3

+/* Safety-net: compact at least every N GCs regardless of threshold.  */
+#define ADAPTIVE_EVERY_N_GCS 64

+static size_t    adaptive_threshold = ADAPTIVE_THRESHOLD_INITIAL;
+static uintmax_t adaptive_ema;          /* bytes-released EMA (fixed point) */
+static bool      adaptive_ema_valid;    /* first sample not yet seen */
+static uintmax_t adaptive_compacts_done;
+static uintmax_t adaptive_bytes_returned;

+static void
+adaptive_update_threshold (size_t bytes_released)
+{
+  if (!adaptive_ema_valid)
+    {
+      adaptive_ema = (uintmax_t) bytes_released;
+      adaptive_ema_valid = true;
+    }
+  else
+    {
+      /* EMA update: ema = alpha * sample + (1-alpha) * ema */
+      adaptive_ema = ((uintmax_t) ADAPTIVE_EMA_ALPHA_NUM * bytes_released
+                      + (uintmax_t) (ADAPTIVE_EMA_ALPHA_DEN - ADAPTIVE_EMA_ALPHA_NUM)
+                        * adaptive_ema)
+                     / ADAPTIVE_EMA_ALPHA_DEN;
+    }

+  /* New threshold: target the EMA itself (compact when freed ~ recent yield).  */
+  size_t new_thresh = (size_t) adaptive_ema;

+  /* Clamp to [ema/2, ema*4] to bound oscillation.  */
+  size_t lo = (size_t) (adaptive_ema * ADAPTIVE_THRESH_MIN_SCALE_NUM
+                         / ADAPTIVE_THRESH_MIN_SCALE_DEN);
+  size_t hi = (size_t) (adaptive_ema * ADAPTIVE_THRESH_MAX_SCALE_NUM
+                         / ADAPTIVE_THRESH_MAX_SCALE_DEN);
+  if (new_thresh < lo) new_thresh = lo;
+  if (new_thresh > hi) new_thresh = hi;

+  /* Never go below 256 KB to prevent compaction-on-every-tiny-GC.  */
+  if (new_thresh < 256 * 1024)
+    new_thresh = 256 * 1024;

+  adaptive_threshold = new_thresh;
+}

+static void
+maybe_compact_memory_adaptive (byte_ct freed_bytes)
+{
+  static uintmax_t gc_counter;
+  static struct timespec last_compact;
+  static bool last_compact_set;

+  bool crossed_threshold = (freed_bytes >= (byte_ct) adaptive_threshold);
+  bool periodic = (++gc_counter >= ADAPTIVE_EVERY_N_GCS);
+  if (!crossed_threshold && !periodic)
+    return;

+  struct timespec now = current_timespec ();
+  if (last_compact_set)
+    {
+      struct timespec elapsed = timespec_sub (now, last_compact);
+      if (timespectod (elapsed) < ADAPTIVE_MIN_INTERVAL_SECS)
+        return;
+    }

+  size_t released = malloc_zone_pressure_relief (NULL, 0);
+  adaptive_compacts_done++;
+  adaptive_bytes_returned += released;
+  last_compact = now;
+  last_compact_set = true;
+  if (periodic) gc_counter = 0;   /* reset periodic counter after firing */

+  adaptive_update_threshold (released);
+}

+#endif /* HAVE_MALLOC_MALLOC_H */

