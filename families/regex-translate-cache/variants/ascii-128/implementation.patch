# LLM-assisted: Claude Code (claude-sonnet-4-6), 2026-06-25
# Variant: 128-entry translate cache covering ASCII codes 0-127 only
# Materially different from baseline: coverage reduced from 256 to 128 entries;
# struct shrinks by 128 bytes; codes 128-255 always use slow path.
diff --git a/src/regex-emacs.c b/src/regex-emacs.c
index d8ed8a462a..0000000000 100644
--- a/src/regex-emacs.c
+++ b/src/regex-emacs.c
@@ -1196,6 +1196,21 @@
 #define RE_TRANSLATE(TBL, C) char_table_translate (TBL, C)
 #define TRANSLATE(d) (!NILP (translate) ? RE_TRANSLATE (translate, d) : (d))

+/* Fast-path translation for ASCII codes 0-127 only.
+
+   The baseline covers 0-255; this variant reduces coverage to 0-127 to
+   save 128 bytes in re_pattern_buffer.  Codes 128-255 always take the
+   slow path via TRANSLATE(C).
+
+   For the common case of case-folded ASCII searches, the fast path covers
+   all characters of interest.  Codes 128-255 in regex patterns (e.g.,
+   Latin-1 case folding) continue to work correctly via the slow path.
+
+   Identity and non-identity translations are both preserved: identity
+   translations (c → c) are stored as-is in trt_ascii[].  */
+#define TRANSLATE_TRU(C)					\
+  ((bufp->trt_ascii_valid && (unsigned) (C) < 128)		\
+   ? (int) bufp->trt_ascii[(unsigned char) (C)]			\
+   : TRANSLATE (C))
+

diff --git a/src/regex-emacs.h b/src/regex-emacs.h
index bcfff662f7..0000000000 100644
--- a/src/regex-emacs.h
+++ b/src/regex-emacs.h
@@ -XXXX,X +XXXX,X @@ struct re_pattern_buffer
-  unsigned char trt_ascii[256];   /* translations for byte codes 0-255 */
+  unsigned char trt_ascii[128];   /* translations for ASCII codes 0-127 */
   bool_bf trt_ascii_valid : 1;

@@ -XXXX,X +XXXX,X @@ re_compile_pattern population block:
-  for (int i = 0; i < 256; i++)
+  for (int i = 0; i < 128; i++)
     {
       int t = char_table_translate (translate, i);
       bufp->trt_ascii[i] = (CHAR_TO_BYTE_SAFE (t) == t)
                             ? (unsigned char) t
                             : (unsigned char) i;
     }
   bufp->trt_ascii_valid = true;
